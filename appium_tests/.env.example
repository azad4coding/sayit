# Copy this to .env and fill in your values (never commit .env)

# ── Test credentials ──────────────────────────────────────────────────────────
TEST_PHONE=+919876543210       # A real phone you can receive OTPs on
TEST_PHONE_2=+919876543211     # Second phone for circle/interaction tests

# ── API base URL ──────────────────────────────────────────────────────────────
API_BASE_URL=https://sayit-gamma.vercel.app

# ── Supabase (for seeding / teardown only) ────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Appium server ─────────────────────────────────────────────────────────────
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723

# ── iOS ───────────────────────────────────────────────────────────────────────
IOS_DEVICE_NAME=iPhone 15 Pro
IOS_PLATFORM_VERSION=17.4
IOS_BUNDLE_ID=com.azad.sayit
# Path to your built .app (simulator) or .ipa (real device)
IOS_APP_PATH=/path/to/SayIt.app

# ── Android ───────────────────────────────────────────────────────────────────
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_PLATFORM_VERSION=14
ANDROID_APP_PACKAGE=com.azad.sayit
ANDROID_APP_ACTIVITY=com.azad.sayit.MainActivity
ANDROID_APP_PATH=/path/to/app-debug.apk
